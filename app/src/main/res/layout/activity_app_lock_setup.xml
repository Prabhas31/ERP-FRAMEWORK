<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create App Lock"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="This password is required to unlock your phone"
        android:layout_marginTop="8dp" />

    <EditText
        android:id="@+id/etAppLockPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter App Lock Password"
        android:inputType="textPassword"
        android:layout_marginTop="24dp" />

    <EditText
        android:id="@+id/etConfirmAppLockPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Confirm App Lock Password"
        android:inputType="textPassword"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CONTINUE"
        android:layout_marginTop="24dp" />

</LinearLayout>
