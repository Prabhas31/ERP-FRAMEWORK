<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 🔐 Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_verify_recovery_password"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- 🔑 Recovery Password -->
    <EditText
        android:id="@+id/etRecoveryPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:hint="@string/hint_recovery_password"
        android:inputType="textPassword"
        android:autofillHints="password"
        android:layout_marginBottom="16dp" />

    <!-- ✅ Verify Button -->
    <Button
        android:id="@+id/btnVerifyPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:text="@string/action_verify"
        android:layout_marginBottom="16dp" />

    <!-- 🔁 Forgot Recovery -->
    <TextView
        android:id="@+id/tvForgotRecovery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="@string/action_forgot_recovery_password"
        android:textColor="?attr/colorPrimary" />

</LinearLayout>
